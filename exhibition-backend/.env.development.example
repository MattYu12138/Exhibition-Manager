# ============================================================
# 本地开发环境配置（复制此文件为 .env，用于本地测试）
# cp .env.development.example .env
# ============================================================

# Shopify 配置（开发用 sandbox store）
SHOPIFY_STORE_DOMAIN=your-dev-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Square 配置（使用 sandbox 环境）
SQUARE_ACCESS_TOKEN=your_square_sandbox_token
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_ENVIRONMENT=sandbox

# 服务器配置
PORT=3001
FRONTEND_URL=http://localhost:5173

# 数据库路径（本地路径，相对于 backend 目录）
DB_PATH=./exhibition.db
SESSION_DB_PATH=./sessions.db

# Session 密钥（本地开发用，可随意填写）
SESSION_SECRET=dev-secret-change-me

# 密码加密密钥（本地开发用，可随意填写，但不能为空）
CRYPTO_SECRET=dev-crypto-key-change-me

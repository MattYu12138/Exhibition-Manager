# ============================================================
# 生产服务器环境配置（仅在服务器上维护，不提交到 git）
# 服务器路径: /home/ubuntu/Exhibition-Manager/backend/.env
# ============================================================

# Shopify 配置（生产 store）
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Square 配置（生产环境）
SQUARE_ACCESS_TOKEN=your_square_production_token
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_ENVIRONMENT=production

# 服务器配置
PORT=3001
FRONTEND_URL=https://your-domain.com

# 数据库路径（Docker 挂载路径）
DB_PATH=/data/exhibition-app/database/exhibition.db
SESSION_DB_PATH=/data/exhibition-app/database/sessions.db

# Session 密钥（生产用，请使用强随机字符串）
SESSION_SECRET=your-strong-random-session-secret-here

# 密码加密密钥（生产用，请使用强随机字符串，一旦设置不可更改）
CRYPTO_SECRET=your-strong-random-crypto-key-here

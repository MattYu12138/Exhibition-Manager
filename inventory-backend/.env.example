PORT=3002
SESSION_SECRET=change-this-to-a-random-string
DB_PATH=../data/LIC_DB.db
SESSION_DB_PATH=../data/sessions.db
FRONTEND_URL=http://localhost:5175
NODE_ENV=development

# Shopify Configuration
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-01

# Square Configuration
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id
# sandbox 或 production
SQUARE_ENVIRONMENT=sandbox

# SSO 配置（与 platform-backend 通信）
# 线下开发：http://localhost:3000
# 线上生产：http://platform-backend:3000（Docker 内部服务名）
PLATFORM_BACKEND_URL=http://localhost:3000
SSO_SECRET=change-this-to-a-random-string

# ============================================================
# 本地开发环境配置（复制此文件为 .env，用于本地测试）
# cp .env.development.example .env
# ============================================================

# 服务器配置
PORT=3002
FRONTEND_URL=http://localhost:5175

# 数据库路径（与 platform-backend 共享同一数据库）
DB_PATH=../data/platform.db
SESSION_DB_PATH=../data/platform-sessions.db

# Session 密钥（与 platform-backend 保持一致）
SESSION_SECRET=dev-platform-secret-change-me

NODE_ENV=development

# Shopify 配置（使用线上真实 store，本地测试只读即可）
SHOPIFY_STORE=lummi-in-colour.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-01

# ============================================================
# Shopify 配置（Dev Dashboard App - client_credentials grant）
# 参考：https://shopify.dev/docs/apps/build/dev-dashboard/get-api-access-tokens
# ============================================================

# 商店名称（不含 .myshopify.com，例如：lummi-in-colour）
SHOPIFY_SHOP=your-store

# Partner Dashboard → 你的 App → Settings 中的凭据
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=your_client_secret

# Access Token（可选）
# 如果填写，系统优先使用此 Token；
# 如果留空，系统会自动用 Client ID + Secret 换取 Token（每 24 小时自动刷新）
SHOPIFY_ACCESS_TOKEN=

# ============================================================
# Square API 配置
# ============================================================
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_ENVIRONMENT=sandbox

# ============================================================
# 服务器配置
# ============================================================
PORT=3001
FRONTEND_URL=http://localhost:5173

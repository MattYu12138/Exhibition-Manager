# Shopify 配置（填入 Access Token 后正常使用）
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shopify OAuth App 凭据（来自 Partner Dashboard，用于一次性授权获取 Token）
# 获取 Token 后此两项可留空
SHOPIFY_API_KEY=your_client_id_from_partner_dashboard
SHOPIFY_API_SECRET=your_client_secret_from_partner_dashboard
SHOPIFY_REDIRECT_URI=http://localhost:3001/auth/callback

# Square API 配置
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_ENVIRONMENT=sandbox

# 服务器配置
PORT=3001
FRONTEND_URL=http://localhost:5173

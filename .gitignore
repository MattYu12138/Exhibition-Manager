# ─── 依赖（全局覆盖所有子目录）────────────────────────────────
node_modules/
**/node_modules/

# ─── 构建产物（全局覆盖所有子目录）──────────────────────────
dist/
**/dist/

# ─── 环境变量（绝不提交到 git）────────────────────────────────
**/.env
**/.env.local
**/.env.production
**/.env.development

# ─── 数据库文件 ────────────────────────────────────────────────
*.db
*.sqlite
**/*.db
**/*.sqlite

# ─── 日志 ──────────────────────────────────────────────────────
*.log
npm-debug.log*

# ─── 系统文件 ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
